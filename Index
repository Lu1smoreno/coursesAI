// Componente auxiliar para resaltar texto
const Highlighter = ({ text, highlight }) => {
  if (!highlight.trim()) return <>{text}</>;
  // Escapar caracteres especiales en la búsqueda
  const escapeRegExp = (string) => string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const regex = new RegExp(`(${escapeRegExp(highlight)})`, 'gi');
  const parts = text.split(regex);
  
  return (
    <>
      {parts.map((part, i) => 
        regex.test(part) 
          ? <mark key={i} className="bg-emerald-500/50 text-emerald-50 rounded px-1 shadow-[0_0_10px_rgba(16,185,129,0.5)]">{part}</mark> 
          : part
      )}
    </>
  );
};

